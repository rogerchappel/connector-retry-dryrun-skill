{
  "name": "connector-retry-dryrun-skill",
  "version": "0.1.0",
  "description": "Local-first retry planner for connector actions with idempotency and approval evidence.",
  "type": "module",
  "bin": {
    "connector-retry-dryrun": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/index.js",
    "dist/index.d.ts",
    "README.md",
    "SKILL.md",
    "docs",
    "fixtures",
    "scripts",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js",
    "demo": "npm run build && bash scripts/demo.sh",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "dry-run",
    "local-first",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/connector-retry-dryrun-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/connector-retry-dryrun-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/connector-retry-dryrun-skill#readme",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4"
  }
}
