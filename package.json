{
  "name": "connector-retry-dryrun-skill",
  "version": "0.1.0",
  "description": "Local-first retry planner for connector actions with idempotency and approval evidence.",
  "type": "module",
  "bin": {
    "connector-retry-dryrun": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "docs",
    "fixtures",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run"
  },
  "keywords": [
    "agent-skill",
    "dry-run",
    "local-first",
    "automation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4"
  }
}
